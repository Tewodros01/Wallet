generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  AGENT
  ADMIN
}

enum Currency {
  USD
  EUR
  GBP
  ETB
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  DEPOSIT
  WITHDRAWAL
  GAME_ENTRY
  GAME_WIN
  AGENT_COMMISSION
  REFERRAL_BONUS
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum RecurrenceInterval {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum RoomStatus {
  WAITING
  PLAYING
  FINISHED
  CANCELLED
}

enum GameSpeed {
  SLOW
  NORMAL
  FAST
}

enum PlayerStatus {
  JOINED
  PLAYING
  WON
  LOST
  LEFT
}

enum PaymentMethod {
  TELEBIRR
  CBE_BIRR
  BANK_CARD
}

enum DepositStatus {
  PENDING
  COMPLETED
  FAILED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REJECTED
}

enum PaymentRequestStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
}

enum AgentStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum TournamentStatus {
  UPCOMING
  LIVE
  FINISHED
  CANCELLED
}

enum MissionType {
  DAILY
  WEEKLY
}

enum MissionCategory {
  PLAY_GAMES
  WIN_GAMES
  DEPOSIT
  INVITE
  TOURNAMENT
  KENO
}

enum NotificationType {
  WIN
  DEPOSIT
  INVITE
  TOURNAMENT
  SYSTEM
  MISSION
  WITHDRAWAL
  TRANSFER
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String    @unique
  password     String
  firstName    String
  lastName     String
  phone        String?   @unique
  avatar       String?
  bio          String?   @db.Text
  telegramId   String?   @unique
  telegramUsername String?
  telegramPhotoUrl String?
  role         Role      @default(USER)
  isVerified     Boolean   @default(false)
  onboardingDone Boolean   @default(false)
  coinsBalance   Int       @default(0)

  wallets      Wallet[]
  sessions     Session[]
  categories   Category[]
  transactions Transaction[]
  deposits     Deposit[]
  withdrawals  Withdrawal[]
  createdPaymentRequests PaymentRequest[] @relation("PaymentRequestCreator")
  paidPaymentRequests    PaymentRequest[] @relation("PaymentRequestPayer")

  // game relations
  hostedRooms  GameRoom[]    @relation("RoomHost")
  roomPlayers  RoomPlayer[]
  bingoCards   BingoCard[]

  // agent relations
  referredBy      AgentInvite? @relation("InvitedUser",  fields: [referredById], references: [id], onDelete: SetNull)
  referredById    String?
  sentInvites     AgentInvite[] @relation("InviterUser")

  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@index([username])
  @@index([telegramId])
  @@index([deletedAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @db.VarChar(512)
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@unique([refreshToken])
  @@index([userId])
}

model Wallet {
  id           String        @id @default(cuid())
  name         String
  balance      Decimal       @default(0) @db.Decimal(19, 4)
  currency     Currency      @default(ETB)
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[] @relation("WalletTransactions")
  transfersOut Transaction[] @relation("TransferSource")
  transfersIn  Transaction[] @relation("TransferDestination")
  isDefault    Boolean       @default(false)
  isActive     Boolean       @default(true)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
  @@index([deletedAt])
}

model Category {
  id           String          @id @default(cuid())
  name         String
  icon         String?
  color        String?
  type         TransactionType
  isSystem     Boolean         @default(false)
  userId       String?
  user         User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  createdAt    DateTime        @default(now())

  @@unique([name, userId])
  @@index([userId])
}

model Transaction {
  id                  String              @id @default(cuid())
  title               String
  amount              Decimal             @db.Decimal(19, 4)
  type                TransactionType
  status              TransactionStatus   @default(COMPLETED)
  note                String?             @db.Text
  date                DateTime
  userId              String
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId            String
  wallet              Wallet              @relation("WalletTransactions", fields: [walletId], references: [id], onDelete: Restrict)
  categoryId          String?
  category            Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  sourceWalletId      String?
  sourceWallet        Wallet?             @relation("TransferSource", fields: [sourceWalletId], references: [id], onDelete: SetNull)
  destinationWalletId String?
  destinationWallet   Wallet?             @relation("TransferDestination", fields: [destinationWalletId], references: [id], onDelete: SetNull)
  isRecurring         Boolean             @default(false)
  recurrenceInterval  RecurrenceInterval?
  recurrenceEndsAt    DateTime?
  parentTransactionId String?
  parentTransaction   Transaction?        @relation("RecurringChildren", fields: [parentTransactionId], references: [id], onDelete: NoAction)
  recurringChildren   Transaction[]       @relation("RecurringChildren")

  // game reference (optional)
  gameRoomId          String?
  gameRoom            GameRoom?           @relation(fields: [gameRoomId], references: [id], onDelete: SetNull)

  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([userId])
  @@index([walletId])
  @@index([categoryId])
  @@index([date])
  @@index([type])
  @@index([status])
  @@index([gameRoomId])
  @@index([parentTransactionId])
  @@index([deletedAt])
}

model GameRoom {
  id           String      @id @default(cuid())
  name         String
  hostId       String
  host         User        @relation("RoomHost", fields: [hostId], references: [id], onDelete: Cascade)
  status       RoomStatus  @default(WAITING)
  speed        GameSpeed   @default(NORMAL)
  entryFee     Int         @default(0)   // in coins
  prizePool    Int         @default(0)   // in coins
  maxPlayers   Int         @default(50)
  cardsPerPlayer Int       @default(1)
  isPrivate    Boolean     @default(false)
  password     String?     // hashed, for private rooms
  winnerId     String?

  players      RoomPlayer[]
  rounds       GameRound[]
  bingoCards   BingoCard[]
  transactions Transaction[]

  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([hostId])
  @@index([status])
  @@index([createdAt])
}

model RoomPlayer {
  id         String       @id @default(cuid())
  roomId     String
  room       GameRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     PlayerStatus @default(JOINED)
  cards      RoomPlayerCard[]
  hasBingo   Boolean      @default(false)
  prize      Int          @default(0)
  joinedAt   DateTime     @default(now())
  finishedAt DateTime?

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model BingoCard {
  id         String          @id @default(cuid())
  userId     String?
  user       User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId     String
  room       GameRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  board      Json            // 5x5 number matrix
  boardHash  String
  playerCard RoomPlayerCard?
  createdAt  DateTime        @default(now())

  @@index([roomId])
  @@index([userId])
  @@unique([roomId, boardHash])
}

model RoomPlayerCard {
  id           String     @id @default(cuid())
  roomPlayerId String
  roomPlayer   RoomPlayer @relation(fields: [roomPlayerId], references: [id], onDelete: Cascade)
  cardId       String     @unique
  card         BingoCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  markedNums   Json       @default("[]")
  createdAt    DateTime   @default(now())

  @@index([roomPlayerId])
  @@index([cardId])
}

model GameRound {
  id          String   @id @default(cuid())
  roomId      String
  room        GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  calledNums  Json     @default("[]")  // ordered array of called numbers
  currentNum  Int?
  roundNumber Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([roomId])
}

model Deposit {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Int           // in coins
  method        PaymentMethod
  reference     String?       @unique  // payment provider reference
  proofUrl      String?       @db.Text // optional payment proof (link, image, pdf)
  status        DepositStatus @default(PENDING)
  failureReason String?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Withdrawal {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Int              // in coins
  method        PaymentMethod
  accountNumber String           // destination account
  status        WithdrawalStatus @default(PENDING)
  failureReason String?
  processedAt   DateTime?
  completedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PaymentRequest {
  id            String               @id @default(cuid())
  creatorId     String
  creator       User                 @relation("PaymentRequestCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  payerId       String?
  payer         User?                @relation("PaymentRequestPayer", fields: [payerId], references: [id], onDelete: SetNull)
  amount        Int
  fee           Int                  @default(0)
  status        PaymentRequestStatus @default(PENDING)
  merchantLabel String?
  note          String?              @db.Text
  reference     String               @unique
  expiresAt     DateTime?
  paidAt        DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([creatorId])
  @@index([payerId])
  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
}

model AgentInvite {
  id           String      @id @default(cuid())
  inviterId    String
  inviter      User        @relation("InviterUser", fields: [inviterId], references: [id], onDelete: Cascade)
  invitedUsers User[]      @relation("InvitedUser")
  code         String      @unique
  status       AgentStatus @default(PENDING)
  commission   Int         @default(0)  // total coins earned from this invite
  usedAt       DateTime?
  expiresAt    DateTime?
  createdAt    DateTime    @default(now())

  @@index([inviterId])
  @@index([code])
}

model Tournament {
  id          String           @id @default(cuid())
  name        String
  subtitle    String?
  prize       Int              @default(0)
  entryFee    Int              @default(0)
  maxPlayers  Int              @default(100)
  status      TournamentStatus @default(UPCOMING)
  sponsored   String?
  startsAt    DateTime
  finishedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  players     TournamentPlayer[]

  @@index([status])
  @@index([startsAt])
}

model TournamentPlayer {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  joinedAt     DateTime   @default(now())

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
}

model Mission {
  id       String          @id @default(cuid())
  title    String
  desc     String
  reward   Int
  total    Int             @default(1)
  type     MissionType
  category MissionCategory
  icon     String          @default("🎯")
  isActive Boolean         @default(true)
  resetAt  DateTime?       // when this mission resets (daily/weekly)
  createdAt DateTime       @default(now())

  userMissions UserMission[]

  @@index([type])
  @@index([isActive])
}

model UserMission {
  id         String   @id @default(cuid())
  userId     String
  missionId  String
  mission    Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  progress   Int      @default(0)
  claimed    Boolean  @default(false)
  claimedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, missionId])
  @@index([userId])
  @@index([missionId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String           @db.Text
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
